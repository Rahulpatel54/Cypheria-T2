{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability — grants core IPC and dialog plugin access.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-save",
    "dialog:allow-open",
    "dialog:allow-message",
    "core:window:allow-close",
    "core:window:allow-minimize",
    "core:window:allow-internal-toggle-maximize"
  ]
}
